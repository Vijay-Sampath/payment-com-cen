    "test:all": "npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "@types/d3": "^7.4.3",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "d3": "^7.9.0",
    "framer-motion": "^11.18.2",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.0",
    "typescript": "^5.9.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.5.8",
    "start-server-and-test": "^2.1.5",
    "tailwindcss": "^3.4.19",
    "vitest": "^4.1.0"
